<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="Theme.VoxCommander" parent="android:Theme.Material.Light.NoActionBar">
        <!-- We use Compose, so these colors are mostly for the system bars -->
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.VoxCommander.Splash" parent="Theme.SplashScreen">
        <!-- Make the system icon transparent to avoid the circular crop -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <!-- Set the branding image as the ACTUAL window background for FULLSCREEN effect -->
        <item name="android:windowBackground">@drawable/splash_logo</item>
        <!-- Fullscreen settings -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="postSplashScreenTheme">@style/Theme.VoxCommander</item>
    </style>
</resources>