<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="Theme.VoxCommander" parent="android:Theme.Material.Light.NoActionBar">
        <!-- We use Compose, so these colors are mostly for the system bars -->
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.VoxCommander.Splash" parent="Theme.SplashScreen">
        <!-- We use a transparent icon here because the REAL splash is set in windowBackground -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <!-- The layer-list background allows us to show the full vertical image centered on black -->
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.VoxCommander</item>
    </style>
</resources>